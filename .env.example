# Server
PORT=3001
NODE_ENV=development

# Security — CHANGE THIS in production to a long random string
JWT_SECRET=changeme_in_production_use_a_long_random_string

# Database (Turso)
# Production: create a free DB at turso.tech, then:
#   TURSO_DATABASE_URL=libsql://your-db-name-yourname.turso.io
#   TURSO_AUTH_TOKEN=your-turso-auth-token
# Local dev: leave blank to use a local SQLite file
TURSO_DATABASE_URL=file:../data/ai-learn.db
TURSO_AUTH_TOKEN=

# Magic link base URL — set to your production domain
MAGIC_LINK_BASE_URL=http://localhost:3000

# Email (Resend) — get a free API key at resend.com
# If not set, magic link tokens are logged to the console instead
RESEND_API_KEY=re_your-api-key-here
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL=AI Learn <noreply@learn.robgregg.com>
